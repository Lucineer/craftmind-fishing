# CraftMind Fishing - Configuration
# Copy to .env and edit as needed

# Persistence directory for ecosystem saves
DATA_DIR=./data/persistence

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Tournament settings
TOURNAMENT_DEFAULT_DURATION=600
TOURNAMENT_MAX_PARTICIPANTS=16

# Economy settings
ECONOMY_MARKET_FILE=./data/persistence/market.json
ECONOMY_ACHIEVEMENTS_FILE=./data/persistence/achievements.json
